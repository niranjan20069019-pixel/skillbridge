# SkillBridge Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key (change this in production)
SECRET_KEY=skillbridge-dev-secret-2024

# YouTube Data API v3 key (optional)
# Without this, the app uses curated fallback video lists.
# To get a key: https://console.cloud.google.com/apis/library/youtube.googleapis.com
# Enable "YouTube Data API v3", create credentials → API key
YOUTUBE_API_KEY=
