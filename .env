# SkillBridge Environment Variables
# ─────────────────────────────────────────────────────────────
# Flask secret key — change this in production
SECRET_KEY=skillbridge-dev-secret-2024

# YouTube Data API v3 key
# ─────────────────────────────────────────────────────────────
# HOW TO GET YOUR FREE KEY:
#   1. Go to https://console.cloud.google.com/
#   2. Create a project (or select existing)
#   3. Go to APIs & Services → Library
#   4. Search "YouTube Data API v3" → Enable it
#   5. Go to APIs & Services → Credentials → Create Credentials → API Key
#   6. Copy the key and paste it below (replace the placeholder)
#
# WITHOUT a key: the app still works using curated fallback videos.
# WITH a key:    the app fetches real top-viewed YouTube videos live.
#
YOUTUBE_API_KEY=
